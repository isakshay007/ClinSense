# Copy to .env and fill in values
# W&B (optional): wandb login or set here
WANDB_API_KEY=
WANDB_ENTITY=your-username

# Kaggle (required for dataset download)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# ── GCP Cloud Run ─────────────────────────────────────────────────────────────
# Used by scripts/deploy_gcp.sh
GCP_PROJECT=clinsense-prod-123456
GCP_REGION=us-central1
# Optional overrides (defaults: SERVICE_NAME=clinsense-api, IMAGE_TAG=latest)
SERVICE_NAME=clinsense-api
IMAGE_TAG=latest

# ── AWS ECS Fargate ───────────────────────────────────────────────────────────
# Used by scripts/deploy_aws.sh
AWS_REGION=us-east-1
ECR_REPO=clinsense-api
ECS_CLUSTER=clinsense
ECS_SERVICE=clinsense-api
